OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_API_KEY=ollama
HTTP_TIMEOUT=60.0
# BẮT BUỘC rõ ràng với Wikipedia/Wikimedia — xem docs/CRAWL.md
# Mẫu: TênTool/Phiên (+URL hoặc email; mô tả) thư việnHTTP
USER_AGENT=crawl-ai/1.0 (+https://example.org/crawl-ai; your-email@example.org) httpx
DATABASE_PATH=data/crawl.db
# MongoDB (tuỳ chọn): đặt MONGODB_URI để lưu documents vào Mongo thay vì SQLite.
# Ví dụ local: mongodb://localhost:27017
MONGODB_URI=
MONGODB_DATABASE=crawl_ai
MONGODB_COLLECTION=documents
MAX_TEXT_CHARS=40000
LLM_MAX_RETRIES=3
LLM_RETRY_BACKOFF_SEC=2.0
# Đặt 1 để chỉ crawl + lưu DB, bỏ qua Ollama (smoke test / CI)
SKIP_LLM=0
# Video KG Search (tuỳ chọn): API đồ thị video nội bộ — federated search trên UI KG Search
VIDEO_KG_BASE_URL=http://172.16.201.209:8009
