# Cấu hình crawl-by-prompt dùng API key (thay cho Ollama local).
# Copy sang .env rồi điền LLM_API_KEY. PHẢI đặt SKIP_LLM=0 để bật gợi ý nguồn.

# --- LLM qua API key (OpenAI-compatible) ---
# OpenAI:        https://api.openai.com/v1   | model: gpt-4o-mini
# Groq:          https://api.groq.com/openai/v1
# Together:      https://api.together.xyz/v1
# OpenRouter:    https://openrouter.ai/api/v1
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_API_KEY=sk-your-key-here

# BẮT BUỘC: 0 để crawl-by-prompt (LLM gợi ý nguồn) hoạt động.
SKIP_LLM=0

# --- Phần còn lại giữ như .env thường ---
HTTP_TIMEOUT=60.0
USER_AGENT=crawl-ai/1.0 (+https://example.org/crawl-ai) httpx
DATABASE_PATH=data/crawl.db
MAX_TEXT_CHARS=40000
LLM_MAX_RETRIES=3
LLM_RETRY_BACKOFF_SEC=2.0

# MongoDB (tuỳ chọn) — để trống thì dùng SQLite.
MONGODB_URI=
MONGODB_DATABASE=crawl_ai
MONGODB_COLLECTION=documents
